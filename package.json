{
  "name": "vbi-product-portal",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -n API,UI -c cyan,magenta \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "db:migrate": "npm run db:migrate -w server",
    "db:seed": "npm run db:seed -w server",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "prettier": "^3.5.0"
  }
}
